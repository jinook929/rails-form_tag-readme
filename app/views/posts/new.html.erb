<h3>Post Form</h3>

<%= form_tag posts_path do %>
  <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
  <%= label_tag :"post[title]", "Post title:" %>
  <%= text_field_tag :"post[title]", "", placeholder: "Title Here" %>
  <%= label_tag :"post[description]", "Post description:" %>
  <%= text_area_tag :"post[description]", "", placeholder: "Some Description" %>
  <%= submit_tag "Submit Post" %>
<% end %>


